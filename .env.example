# GOOGLE_SERVICE_ACCOUNT_JSON=

# --- Auth.js / NextAuth v5 (Phase 3) -----------------------------------------
# Generate with:  openssl rand -base64 32
AUTH_SECRET="AOzmY5jHisOAxSmuZ3pvCt3lTHjrw5ymkii4W3Vdmag="

# MVP/dev convenience: email-only sign-in with NO magic link, NO Resend, NO Upstash.
# Any email present in the ClientAccess tab signs in instantly. MUST be unset/false
# in production. When true, Resend + Upstash below are optional.
ALLOW_DEV_LOGIN="true"

# --- Resend email provider (Phase 3; optional if ALLOW_DEV_LOGIN=true) --------
# API key for sending magic-link emails.
RESEND_API_KEY="re_your_resend_api_key"
# From-address used for magic-link emails (must be a verified Resend sender/domain).
EMAIL_FROM="StreamRev <login@yourdomain.com>"

# --- Auth session store: Upstash Redis ---------------------------------------
# Required ONLY for magic-link sign-in (persists verification tokens). Not needed
# when ALLOW_DEV_LOGIN=true. Also used by the Phase 7 Drive watch store. See guide.md.
UPSTASH_REDIS_REST_URL="https://right-amoeba-157613.upstash.io"
UPSTASH_REDIS_REST_TOKEN="gQAAAAAAAmetAAIgcDJkMTFiYmQ1ZTM2OGE0OWM1YmJkNTFjZDUwMzY1YmEzMA"

# --- Freshness / polling (Phase 6) -------------------------------------------
# SWR client poll interval in milliseconds (default 300000 = 5 minutes).
NEXT_PUBLIC_POLL_INTERVAL_MS="300000"
# Server cache revalidate window in seconds (default 300).
SHEET_CACHE_REVALIDATE_SECONDS="300"

# --- Real-time via Drive push notifications (Phase 7, optional) ---------------
# Leave these unset to run on polling only (Phase 6) — the app works without them.
# Public HTTPS endpoint Google POSTs change notifications to (your deployed URL).
# DRIVE_WEBHOOK_URL="https://yourdomain.com/api/drive/webhook"
# A secret string echoed back by Google in the X-Goog-Channel-Token header; we verify it.
# DRIVE_WATCH_TOKEN="generate-a-random-string"
# Protects the cron renewal endpoint (Vercel Cron sends it as a Bearer token).
# CRON_SECRET="generate-a-random-string"
