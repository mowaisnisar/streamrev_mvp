# =============================================================================
# StreamRev Dashboard — environment variables
# Copy this file to `.env.local` and fill in real values. NEVER commit .env.local.
# =============================================================================

# --- App ---------------------------------------------------------------------
# Public base URL of the app (used by Auth.js for magic-link callbacks).
NEXTAUTH_URL="http://localhost:3000"

# --- Google Sheets (Phase 1) -------------------------------------------------
# The Sheet ID from the Google Sheet URL:
#   https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID="1hmJ4IKrUyOoEkyG26UB-ovz5JTiJc0qvmS1ohki73p8"

# Service-account credentials. Two supported forms — use EITHER:
#   (A) the client email + private key as separate vars (recommended for Vercel), or
#   (B) the whole JSON key as one var (GOOGLE_SERVICE_ACCOUNT_JSON).
GOOGLE_SERVICE_ACCOUNT_EMAIL="healthcare-credentialing@streamrev-501618.iam.gserviceaccount.com"
# Paste the private key with literal \n escapes, wrapped in quotes:
